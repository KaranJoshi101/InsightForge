# Production environment template
# Copy to your host secret manager or deployment environment config.

# Runtime
NODE_ENV=production
SERVER_PORT=5000
TRUST_PROXY=1

# Security
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
JWT_EXPIRE=1h
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Database (MySQL example)
# Option A (recommended on many hosts):
# Use a MySQL connection string when using MySQL
DATABASE_URL=mysql://user:password@host:3306/dbname

# Option B (individual fields):
DB_HOST=localhost
DB_PORT=3306
DB_NAME=insightforge
DB_USER=root
DB_PASSWORD=@Joshi098!
DB_SSL=false

# Frontend API URL used at build/runtime
REACT_APP_API_URL=http://localhost:5002/api

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Optional SMTP fallback settings for providers that block one port
# Example for Gmail fallback: SMTP_FALLBACK_PORT=465 and SMTP_FALLBACK_SECURE=true
SMTP_FALLBACK_HOST=
# For Brevo, 2525 is often the most reliable on PaaS platforms.
SMTP_FALLBACK_PORT=2525
SMTP_FALLBACK_SECURE=
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASS=
SMTP_FALLBACK_FROM_EMAIL=
SMTP_FALLBACK_FROM_NAME=
# Set true to disable automatic 587<->465 retry
SMTP_DISABLE_AUTO_FALLBACK=false
# Force IPv4 on hosts where IPv6 SMTP routes time out (common on PaaS)
SMTP_IP_FAMILY=4
SMTP_USER=surveyproteam@gmail.com
SMTP_PASS=pgvjnwqirluqmkbj
SMTP_FROM_EMAIL=surveyproteam@gmail.com
SMTP_FROM_NAME=InsightForge

# Optional smoke test credentials
# SMOKE_USER_EMAIL=
# SMOKE_USER_PASSWORD=
# SMOKE_API_BASE=https://api.your-domain.com/api
